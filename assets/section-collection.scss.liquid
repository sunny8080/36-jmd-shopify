.jmd-section.section-collection {
  margin: 2rem auto;
}

.jmd-collection-wrapper {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.jmd-collection-details {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 2rem;

  @media screen and (max-width: 750px) {
    flex-direction: column;
  }

  .jmd-collection-title {
    font-size: 2rem;
  }
  .jmd-collection-description {
    max-width: 75%;

    @media screen and (max-width: 1024px) {
      max-width: 100%;
    }
  }

  .jmd-collection-img-container {
    img {
      max-width: 400px;
      max-height: 400px;
      border-radius: 8px;
      width: 100%;
      height: 100%;
      object-position: center;
      object-fit: cover;

      @media screen and (max-width: 750px) {
        max-width: 100%;
      }
    }
  }
}

.jmd-collection-products-nrf {
  margin-top: 1rem;
  text-align: center;
  color: grey;
  font-size: 16px;
}

.jmd-collection-products-wrapper {
  width: 100%;
}

ul.jmd-collection-products {
  width: 100%;
  display: grid;
  gap: 3rem 1rem;
  grid-template-columns: repeat(2, minmax(100px, 1fr));

  @media screen and (min-width: 700px) {
    grid-template-columns: repeat(3, minmax(200px, 1fr));
  }

  @media screen and (min-width: 900px) {
    grid-template-columns: repeat(4, minmax(200px, 1fr));
  }

  @media screen and (min-width: 1024px) {
    grid-template-columns: repeat(5, minmax(200px, 1fr));
  }

  .featured-collection-products-item {
    height: fit-content;
  }
}
